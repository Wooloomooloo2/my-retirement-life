# ===========================================================================
# ADDITIONS TO mrl-ontology.ttl — version 0.9.1
#
# Append this block to mrl-ontology.ttl, then update owl:versionInfo to 0.9.1
#
# Context: ADR-010 — Sister app ontology sharing strategy
# These are backward-compatible additions. No existing MRL classes, properties,
# or individuals are modified. No MRL application code changes are required.
# ===========================================================================


# ---------------------------------------------------------------------------
# CreditCardAccount — subclass of mrl:Account
#
# Models a revolving credit facility. Balance represents the amount currently
# owed (a liability). mrl:isLiability is set to true on all instances.
# ---------------------------------------------------------------------------

mrl:CreditCardAccount a owl:Class ;
    rdfs:label "Credit card account"@en ;
    rdfs:comment "A revolving credit account associated with a payment card. The balance represents a liability — the amount currently owed to the card issuer. Included in net worth calculations as a negative asset."@en ;
    rdfs:subClassOf mrl:Account .

mrl:creditLimit a owl:DatatypeProperty ;
    rdfs:label "credit limit"@en ;
    rdfs:comment "The maximum borrowing limit on this credit card account, in the account's currency."@en ;
    rdfs:domain mrl:CreditCardAccount ;
    rdfs:range xsd:decimal .

mrl:statementDay a owl:DatatypeProperty ;
    rdfs:label "statement day"@en ;
    rdfs:comment "The day of the month on which the card statement is generated (1–31). Optional — used for reconciliation and payment reminders."@en ;
    rdfs:domain mrl:CreditCardAccount ;
    rdfs:range xsd:integer .


# ---------------------------------------------------------------------------
# PropertyAsset — subclass of mrl:Account
#
# Previously declared post-MVP in the class hierarchy comment only. Promoted
# to an active class definition here (ADR-010) to support My Finance Life's
# property tracking. MRL will implement its own property UI in a future release.
#
# Property value is not derived from transactions; instead it is recorded as
# a series of mfl:ValuationEvent instances (defined in the MFL ontology).
# mrl:accountBalance on a PropertyAsset represents the most recent known value.
# ---------------------------------------------------------------------------

mrl:PropertyAsset a owl:Class ;
    rdfs:label "Property asset"@en ;
    rdfs:comment "A real property (residential, commercial, or land) held as an asset. Value is maintained via point-in-time valuation events rather than transaction aggregation. mrl:accountBalance stores the current estimated value in the account currency."@en ;
    rdfs:subClassOf mrl:Account .

mrl:propertyAddress a owl:DatatypeProperty ;
    rdfs:label "property address"@en ;
    rdfs:comment "Free-text postal address of the property."@en ;
    rdfs:domain mrl:PropertyAsset ;
    rdfs:range xsd:string .

mrl:purchasePrice a owl:DatatypeProperty ;
    rdfs:label "purchase price"@en ;
    rdfs:comment "The original purchase price of the property in the account currency. Used for gain/loss calculation."@en ;
    rdfs:domain mrl:PropertyAsset ;
    rdfs:range xsd:decimal .

mrl:purchaseDate a owl:DatatypeProperty ;
    rdfs:label "purchase date"@en ;
    rdfs:comment "The date on which the property was acquired (ISO 8601 date)."@en ;
    rdfs:domain mrl:PropertyAsset ;
    rdfs:range xsd:date .

mrl:isMortgaged a owl:DatatypeProperty ;
    rdfs:label "is mortgaged"@en ;
    rdfs:comment "True if there is an outstanding mortgage on this property. When true, a corresponding liability account should be maintained to correctly reflect net equity."@en ;
    rdfs:domain mrl:PropertyAsset ;
    rdfs:range xsd:boolean .


# ---------------------------------------------------------------------------
# isLiability — datatype property on mrl:Account
#
# Indicates whether this account's balance represents a liability rather than
# an asset. Used by net worth calculations: liability balances are subtracted
# rather than added. Defaults to false if not present (i.e. absence = asset).
# ---------------------------------------------------------------------------

mrl:isLiability a owl:DatatypeProperty ;
    rdfs:label "is liability"@en ;
    rdfs:comment "True if this account's balance is a liability (e.g. credit card debt, mortgage). Liability balances are subtracted from total assets when calculating net worth. Defaults to false (asset) if absent."@en ;
    rdfs:domain mrl:Account ;
    rdfs:range xsd:boolean .


# ---------------------------------------------------------------------------
# CreditCardAccountType — new top concept in mrlx:AccountTypeScheme
#
# Added as a sibling top concept alongside CashAccountType and
# InvestmentAccountType, following the established SKOS pattern.
# ---------------------------------------------------------------------------

# Update mrlx:AccountTypeScheme to include the new top concept.
# In the TTL, add mrlx:CreditCardAccountType to the existing
# skos:hasTopConcept list on mrlx:AccountTypeScheme.
#
# Replace the existing mrlx:AccountTypeScheme block with:
#
#   mrlx:AccountTypeScheme a skos:ConceptScheme ;
#       rdfs:label "Account Type Scheme"@en ;
#       skos:prefLabel "Account Type Scheme"@en ;
#       skos:definition "..." ;
#       skos:hasTopConcept
#           mrlx:CashAccountType ,
#           mrlx:InvestmentAccountType ,
#           mrlx:CreditCardAccountType .          ← add this line
#
# Then append the new concepts below:

mrlx:CreditCardAccountType a skos:Concept ;
    skos:inScheme mrlx:AccountTypeScheme ;
    skos:topConceptOf mrlx:AccountTypeScheme ;
    skos:prefLabel "Credit card account"@en ;
    skos:definition "The parent concept for credit card account types. Credit card balances are liabilities."@en ;
    skos:notation "CC" ;
    skos:scopeNote "Covers revolving credit cards and charge cards. Does not include personal loans, overdrafts, or mortgages, which are modelled as separate liability account types in a future release."@en .

mrlx:CreditCardAccountType_Standard a skos:Concept ;
    skos:inScheme mrlx:AccountTypeScheme ;
    skos:broader mrlx:CreditCardAccountType ;
    skos:prefLabel "Standard credit card"@en ;
    skos:definition "A revolving credit card with a set credit limit. The minimum payment is required each month; any unpaid balance carries interest."@en ;
    skos:notation "CC_STANDARD" ;
    skos:scopeNote "Jurisdiction-neutral. Covers Visa, Mastercard, Amex (revolving), and equivalent revolving credit products worldwide."@en .

mrlx:CreditCardAccountType_ChargeCard a skos:Concept ;
    skos:inScheme mrlx:AccountTypeScheme ;
    skos:broader mrlx:CreditCardAccountType ;
    skos:prefLabel "Charge card"@en ;
    skos:definition "A payment card where the full balance must be paid each month. No revolving credit facility; no interest charged on the balance."@en ;
    skos:notation "CC_CHARGE" ;
    skos:scopeNote "Covers traditional charge card products such as American Express charge cards. Distinct from revolving credit cards in that no balance can be carried forward."@en .


