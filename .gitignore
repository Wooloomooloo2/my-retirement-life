# Virtual environment
.venv/
venv/
env/

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc

# Distribution / packaging
dist/
build/
*.egg-info/

# Environment variables - never commit secrets
.env

# User data - personal triple store data stays local
data/

# PyInstaller build output
*.spec
!tools/MyRetirementLife.spec
*.exe

# VS Code
.vscode/

# OS files
.DS_Store
Thumbs.db

# Test cache
.pytest_cache/
.coverage
htmlcov/
# VS Code personal settings
.vscode/

# Claude Code per-user settings (project-level settings.json is committed)
.claude/settings.local.json
# SQLite WAL/shared-memory sidecars (transient)
*.mfl-wal
*.mfl-shm
*.db-wal
*.db-shm
