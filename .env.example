# My Retirement Life - Environment Configuration
# Copy this file to .env and edit as needed
# .env is excluded from Git - never commit real values

# Application
APP_NAME="My Retirement Life"
APP_HOST=127.0.0.1
# Change this if 8817 is taken; startup fails loudly rather than
# attaching the window to whatever else holds the port.
APP_PORT=8817
DEBUG=true

# Data storage - leave blank to use platform default
# Windows default: %APPDATA%\MyRetirementLife
# Linux default:   ~/.local/share/myretirementlife
DATA_DIR=
